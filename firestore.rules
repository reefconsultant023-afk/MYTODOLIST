rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidTask(data) {
      return data.keys().hasAll(['text', 'category', 'completed', 'createdAt', 'userId'])
        && data.text is string && data.text.size() <= 1000
        && data.category in ['urgent_important', 'urgent_not_important', 'not_urgent_important', 'not_urgent_not_important']
        && data.completed is bool
        && data.createdAt is number
        && data.userId == request.auth.uid
        && (!('domain' in data) || data.domain in ['work', 'personal'])
        && (!('date' in data) || data.date is string)
        && (!('startTime' in data) || data.startTime is string)
        && (!('endTime' in data) || data.endTime is string)
        && (!('subTasks' in data) || data.subTasks is list);
    }

    match /tasks/{taskId} {
      allow create: if isSignedIn() 
        && isValidTask(request.resource.data);
      
      allow update: if isOwner(resource.data.userId)
        && isValidTask(request.resource.data)
        && request.resource.data.userId == resource.data.userId;
        
      allow delete: if isOwner(resource.data.userId);
      
      allow read, list: if isOwner(resource.data.userId);
    }
  }
}
